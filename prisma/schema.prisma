generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(ulid())
  email     String   @unique
  password  String
  firstName String
  lastName  String?
  role      UserRole @default(USER)
  status    Status   @default(ACTIVE)

  refreshToken String?

  orders        Order[]
  tickets       Ticket[]
  reviews       Review[]
  notifications Notification[]
  payments      Payment[]
  organizer     Organizer?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("users")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  startDate   DateTime
  endDate     DateTime
  location    String
  createdAt   DateTime @default(now())

  organizerId String
  organizer   Organizer @relation(fields: [organizerId], references: [id])

  sessions      Session[]
  tickets       Ticket[]
  venue         Venue?         @relation(fields: [venueId], references: [id])
  venueId       String?
  ticketTypes   TicketType[]
  orders        Order[]
  sponsors      Sponsor[]
  reviews       Review[]
  notifications Notification[]
}

model Organizer {
  id          String   @id @default(uuid())
  name        String
  companyName String
  contactInfo String
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  events Event[]
}

model Venue {
  id        String   @id @default(uuid())
  name      String
  address   String
  mapLink   String?
  createdAt DateTime @default(now())

  events Event[]
}

model Session {
  id        String   @id @default(uuid())
  title     String
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  speakers SessionSpeaker[]
  reviews  Review[]
}

model Speaker {
  id        String   @id @default(uuid())
  name      String
  bio       String
  photo     String?
  createdAt DateTime @default(now())

  sessions SessionSpeaker[]
}

model SessionSpeaker {
  id        String   @id @default(uuid())
  sessionId String
  speakerId String
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id])
  speaker Speaker @relation(fields: [speakerId], references: [id])
}

model TicketType {
  id        String   @id @default(uuid())
  name      String
  price     String
  quantity  Int
  createdAt DateTime @default(now())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  tickets Ticket[]
}

model Ticket {
  id        String   @id @default(uuid())
  qrCode    String?
  status    Status
  createdAt DateTime @default(now())

  userId       String
  eventId      String
  ticketTypeId String
  orderId      String?

  user       User       @relation(fields: [userId], references: [id])
  event      Event      @relation(fields: [eventId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  order      Order?     @relation(fields: [orderId], references: [id])
}

model Order {
  id          String      @id @default(uuid())
  totalAmount Float
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())

  userId  String
  eventId String

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  payment Payment?
  tickets Ticket[]
}

model Payment {
  id            String        @id @default(uuid())
  provider      String
  transactionId String?
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())

  userId  String
  orderId String @unique

  user  User  @relation(fields: [userId], references: [id])
  order Order @relation(fields: [orderId], references: [id])
}

model Sponsor {
  id        String   @id @default(uuid())
  name      String
  tier      String
  createdAt DateTime @default(now())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId    String
  eventId   String?
  sessionId String?

  user    User     @relation(fields: [userId], references: [id])
  event   Event?   @relation(fields: [eventId], references: [id])
  session Session? @relation(fields: [sessionId], references: [id])
}

model Notification {
  id         String   @id @default(uuid())
  message    String
  readStatus Boolean  @default(false)
  createdAt  DateTime @default(now())

  userId  String
  eventId String?

  user  User   @relation(fields: [userId], references: [id])
  event Event? @relation(fields: [eventId], references: [id])
}

enum UserRole {
  USER
  ADMIN
  ORGANIZER
}

enum Status {
  ACTIVE
  INACTIVE
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  PORCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}
